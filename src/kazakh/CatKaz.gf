concrete CatKaz of Cat = CommonX ** open Prelude,ResKaz in {
  flags
    coding = "UTF-8" ;
  lincat A = {s : Str} ;
  lincat A2 = {s : Str; lock_A : {}; c2 : {s : Str}} ;
  lincat ACard = {s : Str} ;
  lincat AP = {s : Str} ;
  lincat CN = {s : Case => Str} ;
  lincat Card = {s : Str} ;
