  lincat IQuant = {s : Str} ;
  lincat Imp = {s : Str} ;
  lincat LN = {s : Str} ;
  lincat N = {s : Case => Number => Str;
              poss : Number => Person => Number => Str} ;
  lincat N2 = {s : Case => Number => Str;
               poss : Number => Person => Number => Str; c2 : {s : Str}} ;
  lincat N3 = {s : Case => Number => Str;
               poss : Number => Person => Number => Str; c2 : {s : Str};
               c3 : {s : Str}} ;
