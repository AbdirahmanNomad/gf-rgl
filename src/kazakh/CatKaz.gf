                                    noAspect : Polarity => Person => Number => Str};
                            past : {perfect : Polarity => Person => Number => Str;
                                    progressive : Polarity => Person => Number => Str;
                                    noAspect : Polarity => Person => Number => Str}};
              imperative : Polarity => Formality => Number => Str;
              subjunctive : Person => Number => Str} ;
